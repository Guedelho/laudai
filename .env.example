# Supabase — get these from your project dashboard at supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...

# Google Gemini — get this from https://aistudio.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-api-key

# Stripe — dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...
# Webhook signing secret. Local: `stripe listen --forward-to localhost:3000/api/webhooks/stripe` prints it.
# Production: register the endpoint in dashboard.stripe.com → Webhooks.
STRIPE_WEBHOOK_SECRET=whsec_...
# Recurring price IDs (Stripe Dashboard → Products). Monthly + yearly.
STRIPE_PRICE_ID_MONTHLY=price_...
STRIPE_PRICE_ID_YEARLY=price_...
# Public origin used to build Stripe Checkout return URLs.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google Tag Manager (GA4 + Google Ads). PRODUCTION ONLY — set in Vercel's
# Production environment; leave unset locally and on staging so no tracking loads.
# NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
